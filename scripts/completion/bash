# ---------------------------------------------------------------------------
# Core completion function
# ---------------------------------------------------------------------------
_hermes_loop_completions()
{
    local cur prev words cword split
    _init_completion -s || return

    # ---- ALL BOOLEAN (no-argument) flags ----
    local bool_flags=(
        --accept-hooks
        --check-env
        --checkpoints
