#!/usr/bin/env bash
# bash completion for the infinite-loop daemon (hermes_loop)
# Source: scripts/completion/bash
# Install: source this file, or symlink into /etc/bash_completion.d/
#
# Provides completions for:
#   launch-loop.py
#   python3 launch-loop.py
#   python3 -m hermes_loop
#   run.sh
#   scripts/run-loop.sh

# ---------------------------------------------------------------------------
# Core completion function
# ---------------------------------------------------------------------------
_hermes_loop_completions()
{
    local cur prev words cword split
    _init_completion -s || return

    # ---- ALL BOOLEAN (no-argument) flags ----
    local bool_flags=(
        --no-auto-toolsets
        --no-failure-learning
        --evolve
        --run
        --git
        --git-commit
        --store-git-diff
        --stop-at-goals-end
        --track-goals
        --reset-goals
        --convergence-stop
        --notify-desktop
        --notify-on-completion
        --force-reset
        --use-library
        --pass-session-id
        --checkpoints
        --resume
        --ignore-rules
        --ignore-user-config
        --yolo
        --safe-mode
        --accept-hooks
        --worktree
        --continue
        --quiet
        --preflight
        --preflight-fail-fast
        --dry-run
        --self-test
        --version
        --help
        --list-flags
        --list-groups
        --examples
    )

    # ---- VALUE (argument-taking) flags ----
    local value_flags=(
        --goal
        --context
        --context-file
        --workdir
        --prompt-suffix
        --task-type
        --toolsets
        --max-iterations
        --max-turns
        --compact-every
        --workers
        --session-timeout
        --retry-delay
        --max-retries
        --heartbeat-timeout
        --max-idle-iterations
        --goals-file
        --cooldown
        --cooldown-mode
        --convergence-threshold
        --convergence-window
        --output-schema
        --output-schema-file
        --max-output-chars
        --shutdown-sentinel
        --profile
        --model
        --provider
        --spawn-source
        --webhook-port
        --http-callback
        --notify-cmd
        --on-error-cmd
        --notify-pushbullet
        --notify-ntfy
        --notify-ntfy-server
        --log-file
        --log-max-mb
        --status-html
        --status-file
        --keep-iterations
        --tag
        --archive-dir
        --archive-retention
        --archive-max-size
        --watch-dir
        --watch-poll
        --worker-url
        --skills
        --startup-delay
        --save-config
        --config
    )

    # Flags with specific choice values
    local task_type_choices="auto research code-fix code-build system-admin data-processing content general"
    local cooldown_mode_choices="fixed adaptive"

    # ---- Complete the value after a known value flag ----
    case "$prev" in
        --task-type)
            COMPREPLY=($(compgen -W "$task_type_choices" -- "$cur"))
            return 0
            ;;
        --cooldown-mode)
            COMPREPLY=($(compgen -W "$cooldown_mode_choices" -- "$cur"))
            return 0
            ;;
        --context-file|--goals-file|--output-schema-file|--log-file|--status-file|--status-html|--save-config|--config)
            _filedir
            return 0
            ;;
        --archive-dir|--watch-dir|--workdir)
            _filedir -d
            return 0
            ;;
        --goal|--context|--prompt-suffix|--toolsets|--output-schema|--shutdown-sentinel|--profile|--model|--provider|--spawn-source|--http-callback|--notify-cmd|--on-error-cmd|--notify-pushbullet|--notify-ntfy|--notify-ntfy-server|--tag|--worker-url|--skills)
            return 0
            ;;
        --max-iterations|--max-turns|--compact-every|--workers|--session-timeout|--retry-delay|--max-retries|--heartbeat-timeout|--max-idle-iterations|--cooldown|--convergence-window|--max-output-chars|--log-max-mb|--keep-iterations|--archive-retention|--archive-max-size|--convergence-threshold|--watch-poll|--startup-delay|--webhook-port)
            return 0
            ;;
    esac

    # ---- Offer flag completions ----
    local all_flags=("${bool_flags[@]}" "${value_flags[@]}")

    # Filter out flags that already appear on the command line
    local filtered=()
    local i flag
    for flag in "${all_flags[@]}"; do
        local already=0
        for ((i=0; i < ${#words[@]} - 1; i++)); do
            if [[ "${words[$i]}" == "$flag" ]]; then
                already=1
                break
            fi
        done
        if [[ $already -eq 0 ]]; then
            filtered+=("$flag")
        fi
    done

    if [[ "$cur" == --* ]] || [[ -z "$cur" ]]; then
        COMPREPLY=($(compgen -W "${filtered[*]}" -- "$cur"))
    else
        COMPREPLY=($(compgen -W "${filtered[*]}" -- "$cur"))
    fi

    return 0
}

# ---------------------------------------------------------------------------
# Dispatcher — checks the first words of the command line to decide whether
# we are completing for hermes-loop.
# ---------------------------------------------------------------------------
_hermes_loop_dispatch()
{
    local cmd="${1##*/}"          # basename of the first command word

    # Direct completions for known entry points
    case "$cmd" in
        launch-loop.py|run.sh|run-loop.sh)
            _hermes_loop_completions
            return 0
            ;;
    esac

    # For "python3 <TAB>", check the full command line for our script names
    if [[ "$cmd" == "python3" || "$cmd" == "python" ]]; then
        local line="${COMP_LINE:0:$COMP_POINT}"
        # Match: python3 launch-loop.py ...   or
        #        python3 -m hermes_loop ...
        if [[ "$line" =~ python3\ +launch-loop\.py ]] || \
           [[ "$line" =~ python3\ +-m\ +hermes_loop ]]; then
            # Rewrite $cur/$prev relative to our own offset
            # The easiest way: re-invoke using words shifted past "python3"
            # but _init_completion already handles this via cword correctly
            # when COMP_WORDS has the full line. We just need to figure out
            # whether the "current" word is past the trigger.
            # For simplicity, just check cword >= 2 for launch-loop.py
            # or cword >= 3 for python3 -m hermes_loop
            _hermes_loop_completions
            return 0
        fi
    fi

    return 1
}

# ---------------------------------------------------------------------------
# Register completions
# ---------------------------------------------------------------------------

# Direct commands
complete -F _hermes_loop_dispatch launch-loop.py
complete -F _hermes_loop_dispatch run.sh
complete -F _hermes_loop_dispatch scripts/run-loop.sh

# For python3, we want fallback to default completion behavior when we're
# not completing for hermes-loop. Use -o default to let bash fall through
# to the default completer (file/command completion).
complete -o default -F _hermes_loop_dispatch python3
complete -o default -F _hermes_loop_dispatch python
