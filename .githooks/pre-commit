#!/usr/bin/env bash
# pre-commit hook — run ruff on staged Python files
set -euo pipefail

STAGED_PYTHON_FILES=$(git diff --cached --name-only --diff-filter=ACMR | grep '\.py$' || true)

if [ -z "$STAGED_PYTHON_FILES" ]; then
    echo "[pre-commit] No staged Python files — skipping ruff check."
    exit 0
fi

echo "[pre-commit] Running ruff check on staged Python files..."
ruff check $STAGED_PYTHON_FILES

echo "[pre-commit] Running ruff format check on staged Python files..."
ruff format --check $STAGED_PYTHON_FILES

echo "[pre-commit] All checks passed."
