# =============================================================================
# Infinite Loop Daemon — Configuration (.env / shell environment variables)
# =============================================================================
# This file documents every configurable parameter of launch-loop.py.
# Copy to .env and set values, or pass directly as CLI flags.
# CLI flags override .env values.
#
# Validate your .env with:
#   python3 -m hermes_loop --check-env
#   make check-env
#   bash run.sh --check-env
# =============================================================================

# ── Core Task ─────────────────────────────────────────────────────────────────

# INFINITE_LOOP_GOAL="Refactor the auth module to use JWT tokens"
#   Core task description for spawned Hermes sessions. (Required)

# INFINITE_LOOP_CONTEXT="Code lives in src/auth/. Respond in English."
#   Initial context (paths, constraints, language). Empty string = no context.

# INFINITE_LOOP_CONTEXT_FILE="/path/to/context.txt"
#   Path to file containing context (alternative to CONTEXT). Empty = disabled.

# ── Working Directory ─────────────────────────────────────────────────────────

# INFINITE_LOOP_WORKDIR="/home/nekophobia/Projects/myapp"
#   Working directory for spawned sessions. Defaults to cwd.

# ── Toolsets ──────────────────────────────────────────────────────────────────

# INFINITE_LOOP_TOOLSETS="terminal,file,delegation,web,skills,browser,memory,session_search,code_execution,todo,vision"
#   Comma-separated toolsets for spawned Hermes sessions.
#   'delegation' is auto-added if missing.

# INFINITE_LOOP_NO_AUTO_TOOLSETS=false
#   Set to true to disable automatic toolset enrichment based on task type.

# INFINITE_LOOP_NO_FAILURE_LEARNING=false
#   Set to true to skip injecting past failure context into spawned sessions.

# ── Iteration Control ─────────────────────────────────────────────────────────

# INFINITE_LOOP_MAX_ITERATIONS=0
#   Stop after N iterations. 0 = infinite (until sentinel or convergence).

# INFINITE_LOOP_MAX_TURNS=500
#   Max turns per spawned Hermes session. Needed for deep delegation.

# INFINITE_LOOP_COMPACT_EVERY=5
#   Compact context (window summaries) every N iterations.

# INFINITE_LOOP_EVOLVE=false
#   Set to true to let each iteration propose the next goal (self-directing).

# INFINITE_LOOP_RUN=false
#   Set to true to actually start the loop. Without this, only config is printed.

# ── Parallelism ───────────────────────────────────────────────────────────────

# INFINITE_LOOP_WORKERS=1
#   Number of concurrent Hermes sessions per iteration.

# ── Timeouts ──────────────────────────────────────────────────────────────────

# INFINITE_LOOP_SESSION_TIMEOUT=7200
#   Max seconds per spawned Hermes session (default: 2 hours).

# INFINITE_LOOP_RETRY_DELAY=0
#   Backoff seconds on consecutive errors.

# INFINITE_LOOP_MAX_RETRIES=0
#   Retry a failed iteration up to N times. 0 = no retry.

# INFINITE_LOOP_HEARTBEAT_TIMEOUT=0
#   Enable heartbeat-based session health monitoring. Seconds of inactivity
#   before a session is considered hung. 0 = disabled. Grace period is
#   heartbeat_timeout * 2 (total window = timeout * 3). When a session's
#   heartbeat stops, the daemon kills it and retries. (v14.0.0)

# ── Git Integration ───────────────────────────────────────────────────────────

# INFINITE_LOOP_GIT=false
#   Set to true to capture git diff stats per iteration.

# INFINITE_LOOP_GIT_COMMIT=false
#   Set to true to auto-commit changes per iteration (implies --git).

# INFINITE_LOOP_STORE_GIT_DIFF=false
#   Set to true to store the actual git diff (capped at 10KB) in the ledger.

# INFINITE_LOOP_MAX_IDLE_ITERATIONS=0
#   Stop after N iterations with no git changes. Requires --git. 0 = disabled.

# ── Goal File (Batch Processing) ──────────────────────────────────────────────

# INFINITE_LOOP_GOALS_FILE=""
#   Path to a file with one goal per line. Lines starting with '#' are ignored.
#   Pipe format: goal|profile|model|provider for per-goal overrides.

# INFINITE_LOOP_STOP_AT_GOALS_END=false
#   When used with GOALS_FILE, stop when all goals are exhausted instead of
#   wrapping around.

# INFINITE_LOOP_TRACK_GOALS=false
#   Track completed goals in the ledger via hash. Already-finished goals are
#   skipped on restart. Use with GOALS_FILE.

# INFINITE_LOOP_RESET_GOALS=false
#   Clear the goals_completed tracking in the ledger for a fresh run.

# ── Rate Limiting & Cooldown ──────────────────────────────────────────────────

# INFINITE_LOOP_COOLDOWN=0
#   Wait N seconds between iterations. Useful for API rate-limit awareness.

# INFINITE_LOOP_COOLDOWN_MODE="fixed"
#   Cooldown mode: "fixed" = wait exactly COOLDOWN seconds.
#   "adaptive" = auto-calculate delay based on average iteration duration.
#   Short iterations get longer cooldowns; long iterations get shorter ones.

# ── Convergence Detection ─────────────────────────────────────────────────────

# INFINITE_LOOP_CONVERGENCE_STOP=false
#   Auto-stop when N consecutive iterations produce similar summaries.
#   Uses word-overlap (Jaccard) similarity for stuck detection.

# INFINITE_LOOP_CONVERGENCE_THRESHOLD=0.9
#   Similarity threshold (0.0-1.0). Higher = more permissive (stricter stop).

# INFINITE_LOOP_CONVERGENCE_WINDOW=5
#   Number of recent iterations to compare for convergence.

# ── Structured Output ─────────────────────────────────────────────────────────

# INFINITE_LOOP_OUTPUT_SCHEMA='{"type":"object","required":["summary","duration_seconds"],...}'
#   Inline JSON Schema to validate spawned session output. Uses stdlib-only
#   validation (required fields, types, enum, length/range checks).

# INFINITE_LOOP_OUTPUT_SCHEMA_FILE=""
#   Path to a JSON Schema file for spawned output validation.
#   Alternative to OUTPUT_SCHEMA for complex schemas.

# INFINITE_LOOP_MAX_OUTPUT_CHARS=2000
#   Max chars of spawned output to store. 0 = unlimited.

# ── Sentinel / Shutdown ───────────────────────────────────────────────────────

# INFINITE_LOOP_SHUTDOWN_SENTINEL="/tmp/infinite-loop-stop"
#   Path to sentinel file. Write "stop", "pause", or "resume" to control the
#   loop externally.

# ── Hermes Profile / Model Overrides ──────────────────────────────────────────

# INFINITE_LOOP_PROFILE=""
#   Hermes profile for spawned sessions (e.g. "work").

# INFINITE_LOOP_MODEL=""
#   Model override for spawned sessions (e.g. "anthropic/claude-sonnet-4").

# INFINITE_LOOP_PROVIDER=""
#   Provider override for spawned sessions.

# ── Webhook Server ────────────────────────────────────────────────────────────

# INFINITE_LOOP_WEBHOOK_PORT=0
#   Port for HTTP webhook server. 0 = disabled.
#   POST /webhook → triggers iteration. GET /health, GET /status, GET /api/status.

# ── HTTP Callback ─────────────────────────────────────────────────────────────

# INFINITE_LOOP_HTTP_CALLBACK=""
#   HTTP POST URL for iteration JSON. Alternative to NOTIFY_CMD.

# ── Notifications ─────────────────────────────────────────────────────────────

# INFINITE_LOOP_NOTIFY_CMD=""
#   Shell command to run after each iteration. Receives JSON on stdin.

# INFINITE_LOOP_ON_ERROR_CMD=""
#   Shell command when an iteration fails. Receives JSON on stdin.

# INFINITE_LOOP_NOTIFY_DESKTOP=false
#   Send desktop notifications via notify-send after each iteration (Linux).

# INFINITE_LOOP_NOTIFY_ON_COMPLETION=false
#   Send a summary notification when the daemon finishes.

# INFINITE_LOOP_NOTIFY_PUSHBULLET=""
#   Pushbullet API access token for mobile notifications.
#   Get token at https://www.pushbullet.com/#settings

# INFINITE_LOOP_NOTIFY_NTFY=""
#   ntfy topic name for push notifications (e.g. "my-loop-alerts").
#   Uses ntfy.sh by default.

# INFINITE_LOOP_NOTIFY_NTFY_SERVER="https://ntfy.sh"
#   ntfy server URL. Use a self-hosted server URL for private notifications.

# ── Logging ───────────────────────────────────────────────────────────────────

# INFINITE_LOOP_LOG_FILE=""
#   Path to daemon log file (e.g. /tmp/infinite-loop.log).
#   Adds file logging alongside stdout.

# INFINITE_LOOP_LOG_MAX_MB=10
#   Max log file size in MB before rotation. Only used with LOG_FILE.

# ── Status / Dashboard ────────────────────────────────────────────────────────

# INFINITE_LOOP_STATUS_HTML=""
#   Path to self-contained HTML status dashboard (e.g. /tmp/loop-status.html).
#   Updated after each iteration. Auto-refreshes every 30s.

# INFINITE_LOOP_STATUS_FILE=""
#   Path to write one-line JSON status file for external monitoring.

# ── Ledger Management ─────────────────────────────────────────────────────────

# INFINITE_LOOP_KEEP_ITERATIONS=0
#   Auto-shrink ledger to last N iterations. 0 = keep all.

# INFINITE_LOOP_FORCE_RESET=false
#   Clear existing ledger and start fresh. (Destructive — no archive.)

# INFINITE_LOOP_TAG=""
#   Label/identifier for the run (e.g. "project:fix-auth").

# ── Archiving ─────────────────────────────────────────────────────────────────

# INFINITE_LOOP_ARCHIVE_DIR="$HOME/.hermes/infinite-loop-archives"
#   Directory to store archived iteration JSONL.gz files.

# INFINITE_LOOP_ARCHIVE_RETENTION=30
#   Days to keep archived iterations. 0 = keep forever.

# INFINITE_LOOP_ARCHIVE_MAX_SIZE=0
#   Max total archive directory size in MB before oldest files purged.
#   0 = unlimited. Combined with ARCHIVE_RETENTION, stricter wins.

# ── File Watcher ──────────────────────────────────────────────────────────────

# INFINITE_LOOP_WATCH_DIR=""
#   Watch a directory/file for modifications via os.stat() polling.
#   Triggers an iteration on file change.

# INFINITE_LOOP_WATCH_POLL=5.0
#   File watcher poll interval in seconds. Only used with WATCH_DIR.

# ── Hermes Worker ─────────────────────────────────────────────────────────────

# INFINITE_LOOP_WORKER_URL="auto"
#   Hermes Worker mode. "auto" = daemon auto-starts embedded worker on random
#   port. "http://host:port" = connect to external worker. "" = direct
#   subprocess mode (no worker).

# ── Spawned Session Flags ─────────────────────────────────────────────────────

# INFINITE_LOOP_USE_LIBRARY=false
#   Use AIAgent.run_conversation() in-process instead of spawning subprocess.
#   Falls back to subprocess automatically if AIAgent not importable.

# INFINITE_LOOP_PASS_SESSION_ID=false
#   Store spawned session's session_id in the ledger for inspection/resume.

# INFINITE_LOOP_CHECKPOINTS=false
#   Enable file checkpoints in spawned sessions. Auto-enabled with --git.

# INFINITE_LOOP_RESUME=false
#   Chain spawned sessions across iterations via --resume SESSION_ID.
#   Requires PASS_SESSION_ID.

# INFINITE_LOOP_SKILLS=""
#   Skills to preload in spawned sessions (comma-separated).
#   Subprocess mode only (e.g. "python-debug,code-review").

# INFINITE_LOOP_IGNORE_RULES=false
#   Start spawned sessions without loading AGENTS.md, memory, or rules.

# INFINITE_LOOP_IGNORE_USER_CONFIG=false
#   Skip ~/.hermes/config.yaml in spawned sessions. For isolated runs.

# INFINITE_LOOP_SPAWN_SOURCE="infinite-loop"
#   Source tag passed as --source to hermes chat -q.

# INFINITE_LOOP_YOLO=false
#   Bypass all dangerous command approval prompts in spawned sessions.

# INFINITE_LOOP_SAFE_MODE=false
#   Disable ALL customizations in spawned sessions: config, AGENTS.md,
#   memory, plugins, MCP servers. Troubleshooting mode.

# INFINITE_LOOP_ACCEPT_HOOKS=false
#   Auto-approve shell hooks in spawned sessions without TTY prompt.

# INFINITE_LOOP_WORKTREE=false
#   Run spawned sessions in an isolated git worktree.

# INFINITE_LOOP_CONTINUE=false
#   Resume the most recent session for spawned sessions.

# ── Prompt Customization ──────────────────────────────────────────────────────

# INFINITE_LOOP_PROMPT_SUFFIX=""
#   Extra text appended to every spawned session prompt.

# INFINITE_LOOP_TASK_TYPE="auto"
#   Force task type: research | code-fix | code-build | system-admin |
#   data-processing | content | general. Default: auto-detect from goal.

# ── Startup ───────────────────────────────────────────────────────────────────

# INFINITE_LOOP_STARTUP_DELAY=0.0
#   Wait N seconds before the first iteration.

# INFINITE_LOOP_QUIET=false
#   Set to true to suppress the verbose startup banner, per-iteration headers,
#   and config dump. Shows only compact one-line status updates. Ideal for
#   background daemon runs with log files.

# INFINITE_LOOP_PREFLIGHT=false
#   Run preflight health checks before loop starts. Verifies hermes binary,
#   workdir, git repo, sentinel, file readability, port, disk space.

# INFINITE_LOOP_PREFLIGHT_FAIL_FAST=false
#   Stop on the first preflight check failure instead of running all checks.

# INFINITE_LOOP_DRY_RUN=false
#   Print configuration and exit without starting the loop.

# INFINITE_LOOP_SELF_TEST=false
#   Run in-process self-tests (10 groups, 52 cases across 10 daemon functions) and exit.
#   No spawned sessions are created.

# ── Config Persistence ────────────────────────────────────────────────────────

# INFINITE_LOOP_SAVE_CONFIG=""
#   Save current configuration to a JSON file and exit.

# INFINITE_LOOP_CONFIG=""
#   Load configuration from a JSON file (previously saved with SAVE_CONFIG).
#   CLI flags override file values.
