# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/
*.egg

# Environment
# Note: JSON config (config_file.json) is the recommended format.
# .env/.env.local are git-ignored as defense-in-depth against accidental
# secret commits, even though the project uses JSON config by default.
.env
.env.local
.env.*

# OS
.DS_Store
Thumbs.db

# Editor
*.swp
*.swo
*~
.vscode/
.idea/

# Secret scanning exclusions (detect-secrets baseline)
.secrets.baseline

# pi-loop runtime artifacts (user-specific)
/tmp/infinite-loop-state.json
/tmp/infinite-loop-stop
/tmp/infinite-loop-*.log
.worktrees/
*cover
