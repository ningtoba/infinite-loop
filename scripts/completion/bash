        --notify-on-completion
        --pass-session-id
        --preflight
        --preflight-fail-fast
        --quiet
        --reset-goals
        --resume
        --run
        --safe-mode
        --self-test
        --status
        --stop-at-goals-end
        --store-git-diff
        --track-goals
        --use-library
        --wizard
        --worktree
        --yolo
    )

    # ---- ALL VALUE (argument-taking) flags ----
    local value_flags=(
        --archive-dir
        --archive-max-size
        --archive-retention
        --color
        --compact-every
        --completion-script
        --config
        --context
        --context-file
        --convergence-threshold
        --convergence-window
        --cooldown
        --cooldown-mode
        --explain
        --goal
        --goals-file
        --heartbeat-timeout
        --help-topic
        --http-callback
        --keep-iterations
        --log-file
        --log-max-mb
        --max-idle-iterations
        --max-iterations
        --max-output-chars
        --max-retries
        --max-turns
        --model
        --notify-cmd
        --notify-ntfy
        --notify-ntfy-server
        --notify-pushbullet
        --on-error-cmd
        --output-schema
        --output-schema-file
        --profile
        --prompt-suffix
        --provider
        --retry-delay
        --save-config
        --session-timeout
        --shutdown-sentinel
        --skills
        --spawn-source
        --startup-delay
        --status-file
        --status-html
        --tag
        --task-type
        --toolsets
        --watch-dir
        --watch-poll
        --webhook-port
        --workdir
        --worker-url
        --workers
    )

    # ---- Complete the value after a known value flag ----
    case "$prev" in
        --color)
            COMPREPLY=($(compgen -W "auto always never" -- "$cur"))
            return 0
            ;;
        --completion-script)
            COMPREPLY=($(compgen -W "bash zsh" -- "$cur"))
            return 0
            ;;
        --cooldown-mode)
            COMPREPLY=($(compgen -W "fixed adaptive" -- "$cur"))
            return 0
            ;;
        --config|--context-file|--goals-file|--log-file|--output-schema-file|--save-config|--status-file|--status-html)
            _filedir
            return 0
            ;;

        --archive-dir|--watch-dir|--workdir)
            _filedir -d
            return 0
            ;;

        --archive-max-size|--archive-retention|--compact-every|--context|--convergence-threshold|--convergence-window|--cooldown|--explain|--goal|--heartbeat-timeout|--help-topic|--http-callback|--keep-iterations|--log-max-mb|--max-idle-iterations|--max-iterations|--max-output-chars|--max-retries|--max-turns|--model|--notify-cmd|--notify-ntfy|--notify-ntfy-server|--notify-pushbullet|--on-error-cmd|--output-schema|--profile|--prompt-suffix|--provider|--retry-delay|--session-timeout|--shutdown-sentinel|--skills|--spawn-source|--startup-delay|--tag|--task-type|--toolsets|--watch-poll|--webhook-port|--worker-url|--workers)
            return 0
            ;;
    esac

    # ---- Offer flag completions ----
    local all_flags=("${bool_flags[@]}" "${value_flags[@]}")

    # Filter out flags that already appear on the command line
    local filtered=()
    local i flag
    for flag in "${all_flags[@]}"; do
        local already=0
        for ((i=0; i < ${#words[@]} - 1; i++)); do
            if [[ "${words[$i]}" == "$flag" ]]; then
                already=1
                break
            fi
        done
        if [[ $already -eq 0 ]]; then
            filtered+=("$flag")
        fi
    done

    if [[ "$cur" == --* ]] || [[ -z "$cur" ]]; then
        COMPREPLY=($(compgen -W "${filtered[*]}" -- "$cur"))
    else
        COMPREPLY=($(compgen -W "${filtered[*]}" -- "$cur"))
    fi

    return 0
}

# ---------------------------------------------------------------------------
# Dispatcher -- checks the first words of the command line to decide whether
# we are completing for hermes-loop.
# ---------------------------------------------------------------------------
_hermes_loop_dispatch()
{
    local cmd="${1##*/}"          # basename of the first command word

    # Direct completions for known entry points
    case "$cmd" in
        launch-loop.py|run.sh|run-loop.sh)
            _hermes_loop_completions
            return 0
            ;;
    esac

    # For "python3 <TAB>", check the full command line for our script names
    if [[ "$cmd" == "python3" || "$cmd" == "python" ]]; then
        local line="${COMP_LINE:0:$COMP_POINT}"
        # Match: python3 launch-loop.py ...   or
        #        python3 -m hermes_loop ...
        if [[ "$line" =~ python3\ +launch-loop\.py ]] || \
           [[ "$line" =~ python3\ +-m\ +hermes_loop ]]; then
            _hermes_loop_completions
            return 0
        fi
    fi

    return 1
}

# ---------------------------------------------------------------------------
# Register completions
# ---------------------------------------------------------------------------

# Direct commands
complete -F _hermes_loop_dispatch launch-loop.py
complete -F _hermes_loop_dispatch run.sh
complete -F _hermes_loop_dispatch scripts/run-loop.sh

# For python3, fall back to default completion when not completing for hermes-loop.
complete -o default -F _hermes_loop_dispatch python3
complete -o default -F _hermes_loop_dispatch python

